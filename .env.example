# Project Artemis — .env
# Copy this to .env and fill in values from your Supabase dashboard.
#
# SECURITY NOTE:
# - SUPABASE_ANON_KEY: Safe to commit, used by frontend
# - SUPABASE_URL: Safe to commit
# - SUPABASE_SERVICE_ROLE_KEY: Keep SECRET! Only use in backend/CLI
#   The service_role_key should NOT be exposed in frontend code.

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key

# Optional: only needed if running migrations or backend tools
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
