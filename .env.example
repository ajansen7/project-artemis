# ─── LLM ────────────────────────────────────────────────────────
GOOGLE_API_KEY=your-gemini-api-key
# Optional: Claude fallback for Artisan agent
ANTHROPIC_API_KEY=

# ─── Supabase ───────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─── ChromaDB ───────────────────────────────────────────────────
CHROMA_HOST=localhost
CHROMA_PORT=8000
# Persist path (used when running ChromaDB locally without Docker)
CHROMA_PERSIST_DIR=./data/chroma

# ─── GitHub ─────────────────────────────────────────────────────
GITHUB_TOKEN=your-github-pat
GITHUB_USERNAME=ajansen7

# ─── Google Workspace ──────────────────────────────────────────
# OAuth credentials JSON path (Drive + Gmail)
GOOGLE_CREDENTIALS_PATH=./credentials/google_oauth.json

# ─── External APIs ─────────────────────────────────────────────
PROXYCURL_API_KEY=
FIRECRAWL_API_KEY=
ADZUNA_APP_ID=your-adzuna-app-id
ADZUNA_APP_KEY=your-adzuna-app-key
SERPER_API_KEY=your-serper-api-key

# ─── Discord Bot ────────────────────────────────────────────────
DISCORD_BOT_TOKEN=
DISCORD_GUILD_ID=

# ─── Cost Controls ─────────────────────────────────────────────
MAX_DAILY_LLM_SPEND_USD=2.00
MAX_WEEKLY_PROXYCURL_LOOKUPS=50

# ─── App Settings ──────────────────────────────────────────────
LOG_LEVEL=INFO
ENVIRONMENT=development
