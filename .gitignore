# gitignore template for Project Artemis

# ─── Python ─────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
dist/
build/
.venv/
venv/

# ─── Testing & Linting ─────────────────────────────────────────
.pytest_cache/
.mypy_cache/
.ruff_cache/
htmlcov/
.coverage

# ─── Environment & Secrets ─────────────────────────────────────
.env
credentials/
*.pem
*.key

# ─── Data (local ChromaDB, exports) ────────────────────────────
data/

# ─── LangGraph ──────────────────────────────────────────────────
.langgraph_api/

# ─── Node / Frontend ───────────────────────────────────────────
node_modules/
frontend/.next/
frontend/out/

# ─── IDE ────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
.DS_Store

# ─── Personal Context & Agent Outputs ──────────────────────────
applications/
ingestion/
analysis.md
.claude/skills/scout/references/candidate_context.md
.claude/skills/scout/references/resume_master.md
.claude/skills/scout/references/apply_lessons.md
.claude/skills/scout/references/preferences.md
.claude/skills/scout/references/resume_template.docx
.claude/skills/interview-coach/coaching_state.md
.claude/skills/scout/scripts/update_outreach_messages.py
.claude/skills/scout/scripts/seed_contacts*.py
.claude/skills/scout/scripts/sync_contacts.py
.claude/agent-memory/
*.pdf
*.docx
