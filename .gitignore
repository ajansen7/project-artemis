# gitignore template for Project Artemis

# ─── Python ─────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
dist/
build/
.venv/
venv/

# ─── Testing & Linting ─────────────────────────────────────────
.pytest_cache/
.mypy_cache/
.ruff_cache/
htmlcov/
.coverage

# ─── Environment & Secrets ─────────────────────────────────────
.env
credentials/
*.pem
*.key

# ─── Data (local ChromaDB, exports) ────────────────────────────
data/

# ─── LangGraph ──────────────────────────────────────────────────
.langgraph_api/

# ─── Node / Frontend ───────────────────────────────────────────
node_modules/
frontend/.next/
frontend/out/

# ─── IDE ────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
.DS_Store

# ─── Generated Outputs ────────────────────────────────────────
output/
ingestion/
analysis.md
analysis_*.md

# ─── Claude Code (local/personal) ────────────────────────────
.claude/CLAUDE.local.md
.claude/settings.local.json
.claude/plans/

# ─── Personal Context (skill references, hot memory) ─────────
.claude/skills/hunt/references/candidate_context.md
.claude/skills/hunt/references/preferences.md
.claude/skills/apply/references/resume_master.md
.claude/skills/apply/references/apply_lessons.md
.claude/skills/apply/references/resume_template.docx
.claude/skills/apply/references/form_defaults.md
.claude/skills/interview-coach/coaching_state.md
.claude/skills/blogger/references/
.claude/skills/inbox/references/inbox_state.json
.claude/memory/hot/*
!.claude/memory/hot/*.example.md
!.claude/memory/hot/*.example.json
.claude/memory/MEMORY.md
.claude/memory/*.md
!.claude/memory/hot/

# ─── Channels (local settings) ───────────────────────────────
channels/.claude/settings.local.json

*.pdf
*.docx
